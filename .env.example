NODE_ENV=development
LOG_LEVEL=info
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_VERSION=0.1.0
DATABASE_URL=postgresql://kovi:kovi@localhost:5432/kovi
SESSION_ENCRYPTION_KEY=change-me-to-a-strong-key
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
NATS_URL=nats://localhost:4222
EVENT_BUS_BACKEND=nats-jetstream
REDIS_URL=redis://localhost:6379
REDIS_STREAM_KEY=kovi:events
API_PORT=3000
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW=1 minute
ADMIN_PORT=3100
ADMIN_RATE_LIMIT_MAX=120
ADMIN_RATE_LIMIT_WINDOW=1 minute
WORKER_CONCURRENCY=5
ORCH_MAX_SOURCES=50
ORCH_GLOBAL_PAGE_CONCURRENCY=40
ORCH_PER_SOURCE_CONCURRENCY=4
ORCH_PER_DOMAIN_CONCURRENCY=3
ORCH_STATIC_WORKER_CONCURRENCY=30
ORCH_BROWSER_WORKER_CONCURRENCY=10
ORCH_CIRCUIT_FAILURE_THRESHOLD=5
ORCH_CIRCUIT_OPEN_MINUTES=15
ORCH_DEAD_LETTER_THRESHOLD=3
ORCH_CONTINUE_AS_NEW_PAGE_THRESHOLD=250
ORCH_SCHEDULE_RECONCILE_SECONDS=60

# Secret provider references use KOVI_SECRET_<NORMALIZED_REF>
KOVI_SECRET_DASHBOARD_USERNAME=example-user
KOVI_SECRET_DASHBOARD_PASSWORD=example-password
KOVI_SECRET_DASHBOARD_API_TOKEN=example-token
